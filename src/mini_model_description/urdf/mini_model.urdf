  <!-- ROS 2 Control Hardware Interface -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <!-- PASSIVE SUSPENSION JOINTS (State Interface Only) -->
    <!-- Right Differential Joint -->
    <joint name="Revolute 25">
      <command_interface name="position">
        <param name="min">-0.523599</param>
        <param name="max">0.523599</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Right Bogie Pivot Joint -->
    <joint name="Revolute 26">
      <command_interface name="position">
        <param name="min">-0.523599</param>
        <param name="max">0.523599</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Left Differential Joint -->
    <joint name="Revolute 32">
      <command_interface name="position">
        <param name="min">-0.523599</param>
        <param name="max">0.523599</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Left Bogie Pivot Joint -->
    <joint name="Revolute 33">
      <command_interface name="position">
        <param name="min">-0.523599</param>
        <param name="max">0.523599</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- STEERING JOINTS (Position Command Interface) -->
    <!-- Rear Right Wheel Steering -->
    <joint name="Revolute 27">
      <command_interface name="position">
        <param name="min">-0.785398</param>
        <param name="max">0.785398</param>
        <param name="p">80.0</param>
        <param name="i">1.5</param>
        <param name="d">10.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Front Right Wheel Steering -->
    <joint name="Revolute 28">
      <command_interface name="position">
        <param name="min">-0.785398</param>
        <param name="max">0.785398</param>
        <param name="p">80.0</param>
        <param name="i">1.5</param>
        <param name="d">10.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Front Left Wheel Steering -->
    <joint name="Revolute 34">
      <command_interface name="position">
        <param name="min">-0.785398</param>
        <param name="max">0.785398</param>
        <param name="p">80.0</param>
        <param name="i">1.5</param>
        <param name="d">10.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Rear Left Wheel Steering -->
    <joint name="Revolute 35">
      <command_interface name="position">
        <param name="min">-0.785398</param>
        <param name="max">0.785398</param>
        <param name="p">80.0</param>
        <param name="i">1.5</param>
        <param name="d">10.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- DRIVE JOINTS (Velocity Command Interface) -->
    <!-- Rear Right Wheel Drive -->
    <joint name="Revolute 29">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Middle Right Wheel Drive -->
    <joint name="Revolute 30">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Front Right Wheel Drive -->
    <joint name="Revolute 31">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Front Left Wheel Drive -->
    <joint name="Revolute 36">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Middle Left Wheel Drive -->
    <joint name="Revolute 37">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Rear Left Wheel Drive -->
    <joint name="Revolute 38">
      <command_interface name="velocity">
        <param name="min">-50.0</param>
        <param name="max">50.0</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  <!-- Gazebo ROS 2 Control Plugin -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/mnt/d/Bunker/BaseCamp/Robotics/Rovah/install/mini_model_control/share/mini_model_control/config/rover_controllers.yaml</parameters>
      <controller_manager_name>controller_manager</controller_manager_name>
      <hold_joints>true</hold_joints>
      <position_proportional_gain>0.1</position_proportional_gain>
    </plugin>
  </gazebo>
  <!-- ============================================ -->
  <!-- INTEL REALSENSE D435i RGB-D CAMERA           -->
  <!-- ============================================ -->
  <!-- Camera Link (Housing) -->
  <link name="camera_link">
    <inertial>
      <mass value="0.072"/>
      <!-- 72g actual weight -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- Actual D435i dimensions: 90mm x 25mm x 25mm -->
        <box size="0.09 0.025 0.025"/>
      </geometry>
      <material name="camera_gray"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.09 0.025 0.025"/>
      </geometry>
    </collision>
  </link>
  <!-- Attach camera to front of rover, elevated for better view -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin rpy="0 0 0" xyz="0.45 0.15 0"/>
  </joint>
  <!-- Optical frame (ROS convention: Z forward, Y down, X right) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin rpy="0.0707963267948966 0.0 0.0" xyz="0 0 0"/>
  </joint>
  <!-- Camera Depth Optical Frame -->
  <link name="camera_depth_frame"/>
  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_frame"/>
    <origin rpy="0.0707963267948966 0.0 0.0" xyz="0 0 0"/>
  </joint>
  <!-- ============================================ -->
  <!-- HOKUYO UST-10LX 2D LIDAR (270° Wide Angle)   -->
  <!-- ============================================ -->
  <link name="laser_link">
    <inertial>
      <mass value="0.130"/>
      <!-- 130g typical weight -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- Cylindrical shape: 50mm diameter, 70mm height -->
        <cylinder length="0.07" radius="0.05"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.07" radius="0.05"/>
      </geometry>
    </collision>
  </link>
  <!-- Mount LiDAR on top center for 360° unobstructed view -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin rpy="1.54 0 0" xyz="0.45 0.05 0.0"/>
  </joint>
  <!-- ============================================ -->
  <!-- STANDALONE IMU (9-DOF)                       -->
  <!-- ============================================ -->
  <link name="imu_link">
    <inertial>
      <mass value="0.050"/>
      <!-- 50g typical -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="imu_blue"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
    </collision>
  </link>
  <!-- Place IMU at center of base_link for accurate orientation -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
  </joint>
  <!-- ============================================ -->
  <!-- RTK-GPS (High-Precision Positioning)         -->
  <!-- ============================================ -->
  <link name="gps_link">
    <inertial>
      <mass value="0.020"/>
      <!-- 20g typical -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- GPS antenna: 30mm diameter, 15mm height -->
        <cylinder length="0.015" radius="0.03"/>
      </geometry>
      <material name="gps_green"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <!-- Mount GPS at highest point for best satellite visibility -->
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin rpy="1.54 0 0" xyz="0.0 0.12 0"/>
  </joint>
</robot>
