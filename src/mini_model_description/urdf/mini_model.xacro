<!-- ROS 2 Control Hardware Interface -->
<ros2_control name="GazeboSimSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  
  <!-- PASSIVE SUSPENSION JOINTS (State Interface Only) -->
  <!-- Right Differential Joint -->
  <joint name="Revolute 25">
    <command_interface name="position">
      <param name="min">-0.523599</param>
      <param name="max">0.523599</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Right Bogie Pivot Joint -->
  <joint name="Revolute 26">
    <command_interface name="position">
      <param name="min">-0.523599</param>
      <param name="max">0.523599</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Left Differential Joint -->
  <joint name="Revolute 32">
    <command_interface name="position">
      <param name="min">-0.523599</param>
      <param name="max">0.523599</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Left Bogie Pivot Joint -->
  <joint name="Revolute 33">
    <command_interface name="position">
      <param name="min">-0.523599</param>
      <param name="max">0.523599</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- STEERING JOINTS (Position Command Interface) -->
  <!-- Rear Right Wheel Steering -->
  <joint name="Revolute 27">
    <command_interface name="position">
      <param name="min">-0.785398</param>
      <param name="max">0.785398</param>
      <param name="p">80.0</param>
      <param name="i">1.5</param>
      <param name="d">10.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Front Right Wheel Steering -->
  <joint name="Revolute 28">
    <command_interface name="position">
      <param name="min">-0.785398</param>
      <param name="max">0.785398</param>
      <param name="p">80.0</param>
      <param name="i">1.5</param>
      <param name="d">10.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Front Left Wheel Steering -->
  <joint name="Revolute 34">
    <command_interface name="position">
      <param name="min">-0.785398</param>
      <param name="max">0.785398</param>
      <param name="p">80.0</param>
      <param name="i">1.5</param>
      <param name="d">10.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Rear Left Wheel Steering -->
  <joint name="Revolute 35">
    <command_interface name="position">
      <param name="min">-0.785398</param>
      <param name="max">0.785398</param>
      <param name="p">80.0</param>
      <param name="i">1.5</param>
      <param name="d">10.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- DRIVE JOINTS (Velocity Command Interface) -->
  <!-- Rear Right Wheel Drive -->
  <joint name="Revolute 29">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Middle Right Wheel Drive -->
  <joint name="Revolute 30">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Front Right Wheel Drive -->
  <joint name="Revolute 31">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Front Left Wheel Drive -->
  <joint name="Revolute 36">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Middle Left Wheel Drive -->
  <joint name="Revolute 37">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
  
  <!-- Rear Left Wheel Drive -->
  <joint name="Revolute 38">
    <command_interface name="velocity">
      <param name="min">-50.0</param>
      <param name="max">50.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<!-- Gazebo ROS 2 Control Plugin -->
<gazebo>
  <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <parameters>$(find mini_model_control)/config/rover_controllers.yaml</parameters>
    <controller_manager_name>controller_manager</controller_manager_name>
    <hold_joints>true</hold_joints>
    <position_proportional_gain>0.1</position_proportional_gain>
  </plugin>
</gazebo>

<!-- Attach all autonomous navigation sensors to base_link -->
<xacro:sensors_macro parent="base_link"/>

</robot>
